{
  "name": "agent-skill-manager",
  "version": "2.3.0",
  "description": "Interactive TUI for managing installed skills for AI coding agents (Claude Code, Codex, OpenClaw, and more)",
  "type": "module",
  "bin": {
    "agent-skill-manager": "dist/agent-skill-manager.js",
    "asm": "dist/agent-skill-manager.js"
  },
  "scripts": {
    "start": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/",
    "test:watch": "vitest src/",
    "test:e2e": "vitest run tests/e2e/",
    "test:e2e:node": "vitest run tests/e2e/node-e2e.test.ts",
    "test:e2e:install": "vitest run tests/e2e/npm-install-e2e.test.ts",
    "test:all": "vitest run src/ && npm run build && vitest run tests/e2e/",
    "dev": "tsx src/index.tsx",
    "build": "tsx scripts/build.ts",
    "preindex": "tsx scripts/preindex.ts",
    "build:website": "tsx scripts/build-catalog.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "dist/",
    "data/",
    "scripts/postinstall.cjs",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inkjs/ui": "^2",
    "ink": "^5",
    "react": "^18",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agent-skill-manager",
    "tui",
    "cli",
    "ai-agents",
    "claude-code",
    "codex",
    "openclaw",
    "skills"
  ],
  "author": "luongnv89",
  "license": "MIT",
  "homepage": "https://github.com/luongnv89/agent-skill-manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luongnv89/agent-skill-manager.git"
  },
  "bugs": {
    "url": "https://github.com/luongnv89/agent-skill-manager/issues"
  },
  "devDependencies": {
    "@types/node": "^18",
    "@types/react": "^18",
    "@vitest/ui": "^2",
    "esbuild": "^0.24",
    "ink-testing-library": "^4",
    "minisearch": "7.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
